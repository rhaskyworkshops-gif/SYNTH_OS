void setup() {  

oled.begin(SSD1306_SWITCHCAPVCC, SALIDA_I2C_OLED);

oled.clearDisplay();
oled.setTextSize (1);
oled.setTextColor (WHITE);
oled.setCursor (15,57);
oled.println("RHASKY WORKSHOPS");
oled.drawBitmap(0, 0, logo_rhasky, 128, 57, WHITE);
oled.display();
delay(3000);

 
oled.clearDisplay();
oled.setTextSize (2);
oled.setTextColor (WHITE);
oled.setCursor (15,25);
oled.println("SYNTH OS");
oled.display();
delay(2000);



m.init();
m.setIntensity(Brillo);
m.clear();
pinMode(Boton, INPUT_PULLUP);



}
