void Blink() {
  if ((millis() - debouncetime) >= timeblink) {                    //BLINK ANIMATION
    for (int i = 0; i < 8; i++) {
      column1 = column1 + 1;
      column2 = column2 + 1;
      column3 = column3 - 1;
      column4 = column4 - 1;
      column1L = column1L + 1;
      column2L = column2L + 1;
      column3L = column3L - 1;
      column4L = column4L - 1;

      m.setColumn(column1, 00000000);
      m.setColumn(column2, 00000000);
      m.setColumn(column3, 00000000);
      m.setColumn(column4, 00000000); 
      m.setColumn(column1L, 00000000);
      m.setColumn(column2L, 00000000);
      m.setColumn(column3L, 00000000);
      m.setColumn(column4L, 00000000);
      delay(70); // BLINK RATE
      counter2++;
      debouncetime = millis();
      rising = 1;
      stateblink = 1;
    }
    column1 = -1;
    column2 = 7;
    column3 = 24;
    column4 = 32;
    column1L = 31;
    column2L = 39;
    column3L = 56;
    column4L = 64;
    counter2 = 0;
  }
}



 




























































