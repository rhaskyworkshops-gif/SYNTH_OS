void setup() {  

oled.begin(SSD1306_SWITCHCAPVCC, SALIDA_I2C_OLED);

oled.clearDisplay();
oled.setTextSize (1);
oled.setTextColor (WHITE);
oled.setCursor (15,57);
oled.println("RHASKY WORKSHOPS");
oled.drawBitmap(0, 0, logo_rhasky, 128, 57, WHITE);
oled.display();
delay(3000);

 
oled.clearDisplay();
oled.setTextSize (2);
oled.setTextColor (WHITE);
oled.setCursor (15,25);
oled.println("SYNTH OS");
oled.display();
delay(2000);



m.init();
m.setIntensity(Brillo);
m.clear();
pinMode(Boton, INPUT_PULLUP);


tira.begin();
tira.show();




}
void loop() {


 if (digitalRead(Boton) == LOW) {
  state++;
  if (state > 3) state = 0;
  delay(30);
 }

 tira.setBrightness(180);       // Brightness of the WS2812B LEDs, change the number between 0 and 255 to adjust the brightness

  switch (state) {
  case 0:

  Blink();
  m.writeSprite(32, 0, eyel0);
  m.writeSprite(0, 0, eyer0); 
  oled.clearDisplay();
  oled.drawLine(0,10,128,10,WHITE);
  oled.setTextSize (2);
  oled.setTextColor (WHITE);
  oled.setCursor (30,25);    // CHANGE THE NUMBERS TO MODIFY THE NAME'S POSITION
